---
import Layout from "../layouts/Layout.astro";
import CanvasScroller from "../components/CanvasScroller";
import LiveStats from "../components/DiscordStats";
import { highlight } from "../lib/highlight";
import Logo from "../components/Logo.astro";
import { siteConfig } from "../config/site";
import {
    buildWebsiteJsonLd,
    buildOrganizationJsonLd,
    buildSoftwareJsonLd,
    buildWebApiJsonLd,
    buildFaqJsonLd,
} from "../utils/jsonLd";

const jsonLd = [
    buildWebsiteJsonLd(),
    buildOrganizationJsonLd(),
    buildSoftwareJsonLd(),
    buildWebApiJsonLd(),
    buildFaqJsonLd(),
];

const snippet = `curl https://api.freetheai.xyz/v1/chat/completions \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "yng/gemini-3-1-pro",
    "messages": [{ "role": "user", "content": "Hello" }]
  }'`;
const snippetHtml = await highlight(snippet, "bash");

const pageTitle =
    "Free The AI — Free AI API with 16,000+ Models | No Credit Card";
const pageDescription =
    "Free the AI with FreeTheAi — a free OpenAI-compatible API gateway with 16,000+ models, Discord key signup, streaming chat, tool calling, image generation, and image editing. No credit card, no billing, no daily limits.";
---

<Layout
    title={pageTitle}
    description={pageDescription}
    jsonLd={jsonLd}
    currentPath="/home"
>
    <main>
        <CanvasScroller client:load />

        <!-- Hero Section -->
        <section
            class="home-hero"
            style="max-width:600px;margin:0 auto;padding-top:120px;position:relative;z-index:1;text-align:center"
            data-parallax="0.3"
        >
            <h1 data-parallax="0.2" style="position:relative">
                <Logo
                    width={520}
                    label="FreeTheAI"
                    style="display:block;width:min(92vw,520px);height:auto;margin:0 auto"
                />
                <span class="sr-only"
                    >Free The AI — Free OpenAI-compatible API with 16,000+
                    models</span
                >
            </h1>
            <p
                style="color:var(--muted);font-size:1.15rem;margin:20px auto 0;line-height:1.6;max-width:480px"
            >
                OpenAI-compatible. 16,000+ models.<br />No card. No catch.
            </p>
            <div
                style="margin-top:40px;display:flex;gap:12px;flex-wrap:wrap;justify-content:center"
            >
                <a
                    class="primary-button"
                    href={siteConfig.socials.discord}
                    target="_blank"
                    rel="noreferrer"
                >
                    <span>Get a free API key</span>
                    <span style="opacity:0.6;font-size:0.85rem;margin-left:4px"
                        >&rarr;</span
                    >
                </a>
            </div>
            <div
                style="display:flex;gap:16px;margin-top:16px;justify-content:center"
            >
                <a
                    href="/models"
                    style="color:var(--muted);font-size:0.9rem;text-decoration:underline;text-underline-offset:3px"
                    >Browse Models</a
                >
                <a
                    href="/docs"
                    style="color:var(--muted);font-size:0.9rem;text-decoration:underline;text-underline-offset:3px"
                    >Read Docs</a
                >
            </div>

            <div
                style="margin-top:56px;display:flex;flex-direction:column;align-items:center"
            >
                <LiveStats client:load />
                <a
                    href={siteConfig.socials.discord}
                    target="_blank"
                    rel="noreferrer"
                    style="display:inline-flex;align-items:center;gap:6px;margin-top:16px;color:var(--accent-text);text-shadow:var(--accent-text-glow);font-size:0.85rem;text-decoration:none;font-weight:500"
                >
                    Join Discord <span style="font-size:1rem">&rarr;</span>
                </a>
            </div>

            <div
                class="code-card"
                style="margin-top:64px;text-align:left"
                data-parallax="-0.4"
            >
                <div class="card-head">
                    <div class="dot-row">
                        <span></span><span></span><span></span>
                    </div>
                    <div class="card-label">Try it</div>
                </div>
                <div class="docs-code-group">
                    <div class="shiki-wrapper" set:html={snippetHtml} />
                    <button class="copy-btn" type="button" title="Copy">
                        <span class="material-symbols-outlined"
                            >content_copy</span
                        >
                    </button>
                </div>
            </div>
        </section>

        <!--
        ── Content Section ──
        Visual crescendo: Whisper → Speak → Shout

        Section 1 — Whisper: thin muted accent line, barely there
        Section 2 — Speak:   diptych inset panels, carved into the page
        Section 3 — Shout:   raised accent card, bold orange border

        Three treatments, one system. Every token from SKILL.md.
        Script Architecture (Content System): Define → Show → Act
        -->
        <section class="home-content">
            <div class="rhythm">
                <!-- ═══ Whisper — subtle anchor, establishes the pattern ═══ -->
                <div class="beat whisper">
                    <h2 class="beat-heading">What Is FreeTheAi?</h2>
                    <p class="beat-prose">
                        FreeTheAi is a <strong>free AI API gateway</strong>
                        with 16,000+ models behind a single OpenAI-compatible endpoint.
                        No credit card, no billing, no daily caps — just a free Discord
                        key and a base URL that works with any OpenAI SDK. No prompt
                        storage, no card required. Optional paid slots exist for
                        builders who need separate higher-power models. Built to
                        <strong>free the AI</strong>
                        for developers, students, and builders.
                    </p>
                </div>

                <!-- ═══ Speak — diptych, combinatorial contrast ═══ -->
                <div class="beat">
                    <h2 class="beat-heading">What Can You Build?</h2>

                    <div class="diptych">
                        <div class="diptych-panel">
                            <h3 class="diptych-label">API features</h3>
                            <p>
                                Streaming chat, tool calling and structured
                                outputs, Anthropic messages, image generation,
                                and image editing — all OpenAI-compatible.
                            </p>
                        </div>
                        <div class="diptych-panel">
                            <h3 class="diptych-label">Use cases</h3>
                            <p>
                                Chatbots, coding agents, content pipelines,
                                image tools, and multi-model orchestrations.
                                Students prototype, developers ship, researchers
                                evaluate — all against one free endpoint.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- ═══ Shout — accent card, the bent rule ═══ -->
                <div class="beat shout">
                    <h2 class="beat-heading">Getting Started</h2>

                    <ol class="steps">
                        <li>
                            Join the
                            <a
                                href={siteConfig.socials.discord}
                                target="_blank"
                                rel="noreferrer">FreeTheAi Discord</a
                            >
                        </li>
                        <li>
                            Run <code>/signup</code> in any channel to get your free
                            API key
                        </li>
                        <li>
                            Set <code>FREETHEAI_API_KEY</code> in your environment
                        </li>
                        <li>
                            Point any OpenAI SDK at
                            <code>https://api.freetheai.xyz/v1</code>
                        </li>
                        <li>
                            Browse the
                            <a href="/docs">API docs</a> for endpoint-specific examples
                        </li>
                    </ol>

                    <div class="cta-wrap">
                        <a
                            class="primary-button"
                            href={siteConfig.socials.discord}
                            target="_blank"
                            rel="noreferrer"
                        >
                            Get your free API key
                            <span class="cta-arrow">&rarr;</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        // Lightweight scroll parallax
        const els = document.querySelectorAll("[data-parallax]");
        let ticking = false;
        window.addEventListener(
            "scroll",
            () => {
                if (!ticking) {
                    requestAnimationFrame(() => {
                        const maxY =
                            document.documentElement.scrollHeight -
                            window.innerHeight;
                        const ratio = maxY > 0 ? window.scrollY / maxY : 0;
                        els.forEach((el) => {
                            const speed = parseFloat(
                                el.getAttribute("data-parallax") || "0",
                            );
                            el.style.transform = `translateY(${-ratio * speed * 120}px)`;
                            el.style.willChange = "transform";
                        });
                        ticking = false;
                    });
                    ticking = true;
                }
            },
            { passive: true },
        );
    </script>
</Layout>

<style is:global>
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>

<style>
    /*
     * ═══════════════════════════════════════
     * Content Section — Visual Crescendo
     * ═══════════════════════════════════════
     *
     * Whisper → Speak → Shout
     * Three beats, one rhythm, one system.
     *
     * Section 1 (Whisper): subtle muted left line
     *   — Isolation (RabinnFX #1), First-Frame
     *     Strategy (Content System #7). Establishes
     *     the pattern without demanding attention.
     *
     * Section 2 (Speak): diptych inset panels
     *   — Combinatorial Creativity (Creativity
     *     System #3), A Diptych (RabinnFX #7).
     *     Carved-in feel via sk-inset tokens.
     *
     * Section 3 (Shout): raised accent card
     *   — Chaos/Order edge (Creativity System #5),
     *     The Accent (RabinnFX #2), Von Restorff
     *     Effect (UX Laws). The bent rule.
     *
     * All tokens from SKILL.md. Nothing is ad-hoc.
     */

    .home-content {
        max-width: 720px;
        margin: 80px auto 0;
        padding: 0 24px 80px;
        position: relative;
        z-index: 1;
    }

    /* ── Rhythm grid: three beats, 48px gaps ── */
    .rhythm {
        display: grid;
        gap: 48px;
    }

    .beat {
        /* shared anchor for all three beats */
    }

    /* ── Shared heading ── */
    .beat-heading {
        margin: 0 0 16px;
        color: var(--text);
        font-family: var(--font-serif);
        font-size: 1.6rem;
        font-weight: 600;
    }

    /*
     * ═══ Beat 1: Whisper ═══
     * A 1px muted left border — barely there.
     * Passes the Mute Test (Visual Identity System #1):
     * even blurred, the vertical line anchors the section
     * and connects it to the stronger accents below.
     */
    .whisper {
        padding: 0 0 0 18px;
        border-left: 1px solid var(--border);
    }

    .beat-prose {
        margin: 0;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.8;
    }

    .beat-prose strong {
        color: var(--text);
    }

    /*
     * ═══ Beat 2: Speak ═══
     * Diptych — two panels side by side.
     * The 16px gap between them is where the
     * meaning lives (RabinnFX #7: A Diptych).
     * Inset surface tokens = carved into the page.
     */
    .diptych {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .diptych-panel {
        padding: 20px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .diptych-label {
        margin: 0 0 10px;
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .diptych-panel p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.65;
    }

    /*
     * ═══ Beat 3: Shout ═══
     * Raised shell with 2px orange left border.
     * The ONE bent rule in the system (Chaos/Order).
     * Von Restorff: visually isolates from the
     * descriptive sections above.
     * Peak-End Rule: the CTA button closes the page
     * inside the strongest visual container.
     */
    .shout {
        padding: 24px 24px 24px 28px;
        border: 1px solid var(--sk-border);
        border-left: 2px solid var(--accent);
        border-radius: 0 var(--radius) var(--radius) 0;
        background: var(--sk-shell-bg);
        box-shadow: var(--sk-raised-shadow);
    }

    .shout .beat-heading {
        margin-bottom: 16px;
    }

    /* ── Steps list ── */
    .steps {
        margin: 0 0 24px;
        padding-left: 24px;
        color: var(--muted);
        line-height: 2;
    }

    .steps a {
        color: var(--accent-text);
        text-underline-offset: 3px;
    }

    .steps code {
        color: var(--accent-text);
        background: var(--accent-muted);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
    }

    /* ── CTA ── */
    .cta-wrap {
        margin-top: 28px;
    }

    .cta-arrow {
        opacity: 0.6;
        font-size: 0.85rem;
        margin-left: 4px;
    }

    /*
     * ── Responsive ──
     * Stack diptych, tighten rhythm and accent card.
     */
    @media (max-width: 640px) {
        .diptych {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .shout {
            padding: 20px 16px 20px 20px;
        }

        .whisper {
            padding-left: 14px;
        }

        .rhythm {
            gap: 40px;
        }
    }
</style>
