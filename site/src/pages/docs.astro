---
import Layout from '../layouts/Layout.astro';
import DocsAccordion from '../components/DocsAccordion';
import { buildOrganizationJsonLd, buildSoftwareJsonLd, buildWebsiteJsonLd, buildWebApiJsonLd, buildFaqJsonLd } from '../utils/jsonLd';

const pageDescription = 'FreeTheAi API documentation for chat completions, model listing, image generation, and image editing.';

const jsonLd = [buildWebsiteJsonLd(), buildOrganizationJsonLd(), buildSoftwareJsonLd(), buildWebApiJsonLd(), buildFaqJsonLd()];

const baseSnippet = `Base URL
https://api.freetheai.xyz/v1

Header
Authorization: Bearer YOUR_API_KEY`;

const chatCurlSnippet = `curl https://api.freetheai.xyz/v1/chat/completions \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "yng/gemini-3-1-pro",
    "messages": [
      { "role": "user", "content": "Write a tiny Flask route." }
    ],
    "stream": true
  }'`;

const openAISDKSnippet = `import OpenAI from "openai";

const client = new OpenAI({
  apiKey: process.env.FREETHEAI_API_KEY,
  baseURL: "https://api.freetheai.xyz/v1"
});

const res = await client.chat.completions.create({
  model: "yng/gemini-3-1-pro",
  messages: [{ role: "user", content: "Reply with OK." }]
});

console.log(res.choices[0].message.content);`;

const messagesSnippet = `curl https://api.freetheai.xyz/v1/messages \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "rev/claude-sonnet-4.5",
    "max_tokens": 256,
    "messages": [
      { "role": "user", "content": "Give me a short implementation plan." }
    ]
  }'`;

const modelListSnippet = `curl https://api.freetheai.xyz/v1/models \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY"`;

const fullModelListSnippet = `curl "https://api.freetheai.xyz/v1/models/full" \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY"`;

const vhrImageSnippet = `curl https://api.freetheai.xyz/v1/images/generations \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "vhr/gpt_image_2",
    "prompt": "A cinematic neon sports car parked under rainy city lights"
  }'`;

const imageEditSnippet = `curl https://api.freetheai.xyz/v1/images/edits \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "img/gpt-image-2",
    "prompt": "Improve this logo and make it cleaner",
    "image": "data:image/png;base64,BASE64_IMAGE_HERE"
  }'`;

const pythonImageSnippet = `import base64
import os
from pathlib import Path

import requests

API_KEY = os.environ["FREETHEAI_API_KEY"]
API_BASE = "https://api.freetheai.xyz/v1"


def save_image_result(result, output_path):
    item = (result.get("data") or [{}])[0]
    if item.get("b64_json"):
        Path(output_path).write_bytes(base64.b64decode(item["b64_json"]))
        return
    if item.get("url"):
        image = requests.get(item["url"], timeout=120)
        image.raise_for_status()
        Path(output_path).write_bytes(image.content)
        return
    raise RuntimeError(f"No image found in response: {result}")


res = requests.post(
    f"{API_BASE}/images/generations",
    headers={
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
    },
    json={
        "model": "vhr/gpt_image_2",
        "prompt": "A clean product mockup on a dark desk",
    },
    timeout=180,
)
res.raise_for_status()
save_image_result(res.json(), "generated.png")`;

const endpoints = [
	['POST', '/v1/chat/completions', 'OpenAI-compatible chat, streaming, tool calling, and multi-turn conversations.'],
	['POST', '/v1/messages', 'Anthropic-style Messages API for compatible clients and frameworks.'],
	['GET', '/v1/models', 'Authenticated model list for normal clients.'],
	['GET', '/v1/models/full', 'Expanded model catalog with throughput policy metadata for catalog UIs.'],
	['GET', '/v1/models/leaderboard', 'Site-key model leaderboard for public catalog and landing-page widgets.'],
	['POST', '/v1/images/generations', 'Image generation with img/gpt-image-2 and vhr/* generation models.'],
	['POST', '/v1/images/edits', 'Image editing with img/gpt-image-2 and a base64 data URL input image.'],
	['GET', '/v1/health', 'Public API health and catalog status.'],
];

const imageModels = [
	['img/gpt-image-2', 'Generation + editing', 'Returns base64 image data. Use this for edits.'],
	['vhr/flux_dev', 'Generation only', 'Text-to-image model.'],
	['vhr/gpt_image_2', 'Generation only', 'Text-to-image model.'],
	['vhr/nano_banana_2', 'Generation only', 'Text-to-image model.'],
	['vhr/bytedance_seedream_v4', 'Generation only', 'Text-to-image model.'],

];
---

<Layout
	title="FreeTheAi API Docs - Chat, Models, Images"
	description={pageDescription}
	jsonLd={jsonLd}
	currentPath="/docs"
>
	<main class="docs-main" data-docs-nav>
		<button class="docs-section-toggle" type="button" aria-controls="docs-section-nav" aria-expanded="false">
			Docs sections
		</button>
		<section class="docs-layout">
			<aside class="docs-sidebar" id="docs-section-nav" aria-label="Docs sections">
				<span class="docs-sidebar-label">On this page</span>
				<a href="#auth">Auth</a>
				<a href="#endpoints">Endpoints</a>
				<a href="#chat">Chat</a>
				<a href="#messages">Messages</a>
				<a href="#models">Models</a>
				<a href="#images">Images</a>
				<a href="#errors">Errors</a>
			</aside>

			<div class="docs-content">
				<div class="docs-content-head">
					<h1>API Docs</h1>
					<p>Chat, models, images — one key, one base URL.</p>
				</div>
				<DocsAccordion
					baseSnippet={baseSnippet}
					chatCurlSnippet={chatCurlSnippet}
					openAISDKSnippet={openAISDKSnippet}
					messagesSnippet={messagesSnippet}
					modelListSnippet={modelListSnippet}
					fullModelListSnippet={fullModelListSnippet}
					vhrImageSnippet={vhrImageSnippet}
					imageEditSnippet={imageEditSnippet}
					pythonImageSnippet={pythonImageSnippet}
					endpoints={endpoints}
					imageModels={imageModels}
				/>
			</div>
		</section>
	</main>

	<script>
		const docsRoot = document.querySelector('[data-docs-nav]');
		const docsToggle = docsRoot?.querySelector('.docs-section-toggle');
		const docsSidebar = docsRoot?.querySelector('#docs-section-nav');

		if (docsRoot instanceof HTMLElement && docsToggle instanceof HTMLButtonElement && docsSidebar instanceof HTMLElement) {
			const mobileDocsQuery = window.matchMedia('(max-width: 820px)');

			const setDocsSectionsOpen = (open) => {
				docsRoot.toggleAttribute('data-sections-open', open);
				docsToggle.setAttribute('aria-expanded', String(open));

				const hidden = mobileDocsQuery.matches && !open;
				docsSidebar.toggleAttribute('aria-hidden', hidden);
				if ('inert' in docsSidebar) docsSidebar.inert = hidden;
			};

			const syncDocsSections = () => {
				if (!mobileDocsQuery.matches) {
					setDocsSectionsOpen(false);
					docsSidebar.removeAttribute('aria-hidden');
					if ('inert' in docsSidebar) docsSidebar.inert = false;
					return;
				}

				setDocsSectionsOpen(docsRoot.hasAttribute('data-sections-open'));
			};

			docsToggle.addEventListener('click', () => {
				setDocsSectionsOpen(!docsRoot.hasAttribute('data-sections-open'));
			});

			docsSidebar.addEventListener('click', (event) => {
				if (event.target instanceof Element && event.target.closest('a')) setDocsSectionsOpen(false);
			});

			document.addEventListener('pointerdown', (event) => {
				if (!mobileDocsQuery.matches || !docsRoot.hasAttribute('data-sections-open') || !(event.target instanceof Node)) return;
				if (!docsSidebar.contains(event.target) && !docsToggle.contains(event.target)) setDocsSectionsOpen(false);
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') setDocsSectionsOpen(false);
			});

			mobileDocsQuery.addEventListener('change', syncDocsSections);
			syncDocsSections();
		}
	</script>
</Layout>
