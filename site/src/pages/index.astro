---
import BaseHead from '../components/BaseHead.astro';
import { siteConfig } from '../config/site';
import { buildOrganizationJsonLd, buildSoftwareJsonLd, buildWebsiteJsonLd } from '../utils/jsonLd';

const pageDescription =
	'FreeTheAi — free OpenAI-compatible API. Get a key via Discord, use chat, streaming, tools, images, and 15k+ models.';

const jsonLd = [buildWebsiteJsonLd(), buildOrganizationJsonLd(), buildSoftwareJsonLd()];

const requestSnippet = `curl https://api.freetheai.xyz/v1/chat/completions \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "glm/glm-5.1",
    "messages": [
      {
        "role": "user",
        "content": "Build me a clean product launch checklist"
      }
    ],
    "stream": true
  }'`;

const sdkSnippet = `import OpenAI from "openai";

const client = new OpenAI({
  apiKey: process.env.FREETHEAI_API_KEY,
  baseURL: "https://api.freetheai.xyz/v1"
});

const response = await client.chat.completions.create({
  model: "glm/glm-5.1",
  messages: [{ role: "user", content: "Ship a tiny REST API example." }],
  stream: true
});`;

const messagesSnippet = `curl https://api.freetheai.xyz/v1/messages \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "rev/claude-sonnet-4.5",
    "max_tokens": 256,
    "messages": [
      { "role": "user", "content": "Reply with a compact migration plan." }
    ]
  }'`;

const proofStats = [
	{
		value: '2k',
		label: 'members',
		copy: 'Active builder community on Discord.',
	},
	{
		value: '700+',
		label: 'users',
		copy: 'Registered and building real projects.',
	},
	{
		value: '$0',
		label: 'cost',
		copy: 'No billing, no cards, no paid tiers.',
	},
	{
		value: '15k+',
		label: 'models',
		copy: 'Chat, images, tools — one key.',
	},
];

const quickSteps = [
	{
		icon: 'forum',
		title: 'Join Discord',
		copy: 'Signup and support happen in the community server.',
	},
	{
		icon: 'vpn_key',
		title: 'Run /signup',
		copy: 'Get your API key instantly. Use /resetkey if you lose it.',
	},
	{
		icon: 'code_blocks',
		title: 'Use any SDK',
		copy: 'Point your OpenAI-compatible client at our base URL.',
	},
	{
		icon: 'travel_explore',
		title: 'Browse models',
		copy: 'Search the full catalog on the /models page.',
	},
];

const capabilities = [
	{
		icon: 'bolt',
		title: 'Streaming chat',
		copy: 'Standard chat completions for apps, CLIs, and agents.',
		route: 'POST /v1/chat/completions',
	},
	{
		icon: 'handyman',
		title: 'Tool calling',
		copy: 'OpenAI tool schemas with structured function responses.',
		route: 'tools + tool_choice',
	},
	{
		icon: 'alternate_email',
		title: 'Messages API',
		copy: 'Anthropic-style messages route for compatible frameworks.',
		route: 'POST /v1/messages',
	},
	{
		icon: 'imagesmode',
		title: 'Image generation',
		copy: 'Generate images with img/gpt-image-2.',
		route: 'POST /v1/images/generations',
	},
	{
		icon: 'edit_square',
		title: 'Image edits',
		copy: 'Edit images with prompt + base64 input.',
		route: 'POST /v1/images/edits',
	},
];

const fairnessItems = [
	'No billing page, no paid plans.',
	'Community-managed via Discord and fair-use tiers.',
	'Searchable model catalog on /models.',
	'Usage metadata only — no prompt/completion storage.',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="FreeTheAi - Free OpenAI-compatible AI API"
			description={pageDescription}
			jsonLd={jsonLd}
		/>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<nav class="nav">
					<a class="brand" href="/" aria-label="FreeTheAi home">
						<span class="brand-mark">FTA</span>
						<span>FreeTheAi</span>
					</a>
					<div class="nav-links">
						<a href="#quickstart">Quickstart</a>
						<a href="#capabilities">API</a>
						<a href="#free">Free</a>
						<a href="/models">Models</a>
						<a href={siteConfig.socials.github} target="_blank" rel="noreferrer">Repo</a>
					</div>
					<a class="discord-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
						<span class="material-symbols-outlined">forum</span>
						<span>Join Discord</span>
					</a>
				</nav>
			</header>

			<main>
				<section class="hero landing-hero">
					<div class="hero-copy">
						<div class="eyebrow">FREE AI API FOR BUILDERS</div>
						<h1>Free AI API for builders.</h1>
						<p class="hero-text">
							OpenAI-compatible gateway with chat, streaming, tools, images, and 15k+ models.
							Get a free API key through Discord.
						</p>
						<div class="hero-actions">
							<a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
								<span class="material-symbols-outlined">vpn_key</span>
								<span>Get a Free API Key</span>
							</a>
							<a class="ghost-button" href="/models">
								<span class="material-symbols-outlined">travel_explore</span>
								<span>Browse Models</span>
							</a>
						</div>
						<div class="hero-note">
							<span class="material-symbols-outlined">verified</span>
							<span>No paid plans. No card required.</span>
						</div>
					</div>

					<div class="hero-console" aria-label="FreeTheAi API example">
						<div class="console-glow"></div>
						<div class="code-card hero-code-card">
							<div class="card-head">
								<div class="dot-row"><span></span><span></span><span></span></div>
								<div class="card-label">OpenAI-compatible request</div>
							</div>
							<pre><code>{requestSnippet}</code></pre>
						</div>
						<div class="console-chip chip-a">
							<span class="material-symbols-outlined">stream</span>
							Streaming
						</div>
						<div class="console-chip chip-b">
							<span class="material-symbols-outlined">build</span>
							Tool calls
						</div>
						<div class="console-chip chip-c">
							<span class="material-symbols-outlined">imagesmode</span>
							Media
						</div>
					</div>
				</section>

				<section class="proof-grid" aria-label="FreeTheAi usage proof">
					{proofStats.map((stat) => (
						<article class="proof-card">
							<strong>{stat.value}</strong>
							<span>{stat.label}</span>
							<p>{stat.copy}</p>
						</article>
					))}
				</section>

				<section class="section split-section" id="quickstart">
					<div class="section-head sticky-copy">
						<div class="eyebrow">QUICKSTART</div>
						<h2>Get started in under a minute.</h2>
						<p>
							Join the server, run <code>/signup</code>, set your base URL, and start building.
						</p>
						<a class="inline-link" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
							<span class="material-symbols-outlined">open_in_new</span>
							<span>Open the Discord signup flow</span>
						</a>
					</div>
					<div class="steps-grid vertical-steps">
						{quickSteps.map((step, index) => (
							<article class="step-card">
								<div class="step-index">0{index + 1}</div>
								<span class="material-symbols-outlined">{step.icon}</span>
								<h3>{step.title}</h3>
								<p>{step.copy}</p>
							</article>
						))}
					</div>
				</section>

				<section class="section" id="capabilities">
					<div class="section-head">
						<div class="eyebrow">API SURFACE</div>
						<h2>API surface</h2>
						<p>
							Multiple workloads behind one key. Full model catalog on the models page.
						</p>
					</div>
					<div class="capability-grid">
						{capabilities.map((item) => (
							<article class="capability-card">
								<div class="capability-icon">
									<span class="material-symbols-outlined">{item.icon}</span>
								</div>
								<h3>{item.title}</h3>
								<p>{item.copy}</p>
								<code>{item.route}</code>
							</article>
						))}
					</div>
				</section>

				<section class="section code-section" id="usage">
					<div class="section-head">
						<div class="eyebrow">COPY, PASTE, SHIP</div>
						<h2>Code examples</h2>
						<p>
							Chat completions for most apps. <code>/v1/messages</code> for Anthropic-style frameworks.
						</p>
					</div>
					<div class="usage-grid">
						<div class="panel code-panel">
							<div class="panel-kicker">JavaScript SDK</div>
							<h3>OpenAI-compatible client</h3>
							<pre><code>{sdkSnippet}</code></pre>
						</div>
						<div class="panel code-panel">
							<div class="panel-kicker">Messages route</div>
							<h3>Anthropic-style request shape</h3>
							<pre><code>{messagesSnippet}</code></pre>
						</div>
					</div>
				</section>

				<section class="models-cta" id="models">
					<div>
						<div class="eyebrow">MODEL CATALOG</div>
						<h2>Full model catalog</h2>
						<p>
							Search the live catalog, browse tiers, and find exact aliases on the
							<a href="/models">models page</a>.
						</p>
					</div>
					<div class="model-orbit" aria-hidden="true">
						<div class="orbit-ring"></div>
						<div class="orbit-pill pill-one">chat</div>
						<div class="orbit-pill pill-two">tools</div>
						<div class="orbit-pill pill-three">media</div>
						<div class="orbit-pill pill-four">edits</div>
						<div class="orbit-center">/models</div>
					</div>
					<a class="primary-button" href="/models">
						<span class="material-symbols-outlined">search</span>
						<span>Search Live Models</span>
					</a>
				</section>

				<section class="section two-panel" id="free">
					<div class="panel free-panel">
						<div class="eyebrow">WHY FREE</div>
						<h2>No charge. Ever.</h2>
						<p>
							Community-run with fair-use controls. No pricing page.
						</p>
						<ul class="privacy-list">
							{fairnessItems.map((item) => (
								<li>
									<span class="material-symbols-outlined">check_circle</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
					<div class="panel privacy-panel">
						<div class="eyebrow">PRIVACY POSTURE</div>
						<h2>Privacy</h2>
						<div class="privacy-columns">
							<div>
								<h3>Tracked</h3>
								<ul class="privacy-list">
									<li><span class="material-symbols-outlined">check_circle</span>model id</li>
									<li><span class="material-symbols-outlined">check_circle</span>token counts</li>
									<li><span class="material-symbols-outlined">check_circle</span>status code</li>
									<li><span class="material-symbols-outlined">check_circle</span>timestamp</li>
								</ul>
							</div>
							<div>
								<h3>Not stored</h3>
								<ul class="privacy-list">
									<li><span class="material-symbols-outlined">block</span>prompt text</li>
									<li><span class="material-symbols-outlined">block</span>completion text</li>
									<li><span class="material-symbols-outlined">block</span>billing data</li>
									<li><span class="material-symbols-outlined">block</span>credit card data</li>
								</ul>
							</div>
						</div>
					</div>
				</section>

				<section class="cta-banner">
					<div>
						<div class="eyebrow">START NOW</div>
						<h2>Get a key and start building.</h2>
						<p>
							2k members, 700+ registrations, zero billing.
						</p>
					</div>
					<div class="cta-actions">
						<a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
							<span class="material-symbols-outlined">forum</span>
							<span>Join Discord</span>
						</a>
						<a class="ghost-button" href="/models">
							<span class="material-symbols-outlined">travel_explore</span>
							<span>Open Models</span>
						</a>
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
