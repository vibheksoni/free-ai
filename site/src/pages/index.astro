---
import BaseHead from '../components/BaseHead.astro';
import { siteConfig } from '../config/site';
import { buildOrganizationJsonLd, buildSoftwareJsonLd, buildWebsiteJsonLd } from '../utils/jsonLd';

const pageDescription =
	'FreeTheAi is a free OpenAI-compatible AI API for builders. Get a Discord API key, use streaming, tool calling, images, video, speech, and a live model catalog with no billing.';

const jsonLd = [buildWebsiteJsonLd(), buildOrganizationJsonLd(), buildSoftwareJsonLd()];

const requestSnippet = `curl https://api.freetheai.xyz/v1/chat/completions \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "glm/glm-5.1",
    "messages": [
      {
        "role": "user",
        "content": "Build me a clean product launch checklist"
      }
    ],
    "stream": true
  }'`;

const sdkSnippet = `import OpenAI from "openai";

const client = new OpenAI({
  apiKey: process.env.FREETHEAI_API_KEY,
  baseURL: "https://api.freetheai.xyz/v1"
});

const response = await client.chat.completions.create({
  model: "glm/glm-5.1",
  messages: [{ role: "user", content: "Ship a tiny REST API example." }],
  stream: true
});`;

const messagesSnippet = `curl https://api.freetheai.xyz/v1/messages \\
  -H "Authorization: Bearer $FREETHEAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "rev/claude-sonnet-4.5",
    "max_tokens": 256,
    "messages": [
      { "role": "user", "content": "Reply with a compact migration plan." }
    ]
  }'`;

const proofStats = [
	{
		value: '2k',
		label: 'Discord members soon',
		copy: 'A fast-growing builder community around one free API key flow.',
	},
	{
		value: '700+',
		label: 'registered users',
		copy: 'People are already signing up and testing real projects.',
	},
	{
		value: '$0',
		label: 'charged',
		copy: 'No paid plans, no billing page, no card prompt.',
	},
	{
		value: '1 key',
		label: 'many routes',
		copy: 'Chat, streaming, tools, media, speech, and model browsing.',
	},
];

const quickSteps = [
	{
		icon: 'forum',
		title: 'Join Discord',
		copy: 'Everything starts in the community. The signup flow lives there so key rotation and support stay simple.',
	},
	{
		icon: 'vpn_key',
		title: 'Run /signup',
		copy: 'The bot gives you an API key. If you lose it later, use /resetkey instead of making a new account.',
	},
	{
		icon: 'code_blocks',
		title: 'Use the OpenAI shape',
		copy: 'Point your OpenAI-compatible SDK at our base URL and keep using the client code you already know.',
	},
	{
		icon: 'travel_explore',
		title: 'Browse /models',
		copy: 'The homepage stays lightweight. The full searchable catalog has its own page with tiers and aliases.',
	},
];

const capabilities = [
	{
		icon: 'bolt',
		title: 'Streaming chat',
		copy: 'Use the standard chat completions route for fast interactive apps, CLIs, and agents.',
		route: 'POST /v1/chat/completions',
	},
	{
		icon: 'handyman',
		title: 'Tool calling',
		copy: 'Send normal OpenAI tool schemas and let supported aliases return structured tool calls.',
		route: 'tools + tool_choice',
	},
	{
		icon: 'alternate_email',
		title: 'Messages API',
		copy: 'Use an Anthropic-style messages route when your client or agent framework expects it.',
		route: 'POST /v1/messages',
	},
	{
		icon: 'imagesmode',
		title: 'Images',
		copy: 'Generate image assets through the same API key and a familiar generation route.',
		route: 'POST /v1/images/generations',
	},
	{
		icon: 'movie',
		title: 'Video jobs',
		copy: 'Start deferred video generations and poll by request id until the result is ready.',
		route: 'POST /v1/videos/generations',
	},
	{
		icon: 'volume_up',
		title: 'Text to speech',
		copy: 'Create voice output with supported voices and wrappers for lightweight audio workflows.',
		route: 'POST /v1/audio/speech',
	},
];

const fairnessItems = [
	'No subscription checkout and no paid upgrade funnel.',
	'Access is community-managed through Discord signup and fair-use tiers.',
	'The public model catalog is searchable on /models instead of dumped on the homepage.',
	'Request logging focuses on usage metadata, not storing prompt or completion text.',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="FreeTheAi - Free OpenAI-compatible AI API"
			description={pageDescription}
			jsonLd={jsonLd}
		/>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<nav class="nav">
					<a class="brand" href="/" aria-label="FreeTheAi home">
						<span class="brand-mark">FTA</span>
						<span>FreeTheAi</span>
					</a>
					<div class="nav-links">
						<a href="#quickstart">Quickstart</a>
						<a href="#capabilities">API</a>
						<a href="#free">Free</a>
						<a href="/models">Models</a>
						<a href={siteConfig.socials.github} target="_blank" rel="noreferrer">Repo</a>
					</div>
					<a class="discord-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
						<span class="material-symbols-outlined">forum</span>
						<span>Join Discord</span>
					</a>
				</nav>
			</header>

			<main>
				<section class="hero landing-hero">
					<div class="hero-copy">
						<div class="eyebrow">FREE AI API FOR BUILDERS</div>
						<h1>Build with AI without opening a billing page.</h1>
						<p class="hero-text">
							FreeTheAi gives you a free API key through Discord and a real OpenAI-compatible gateway
							for chat, streaming, tool calls, images, video, speech, and a live model catalog.
						</p>
						<div class="hero-actions">
							<a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
								<span class="material-symbols-outlined">vpn_key</span>
								<span>Get a Free API Key</span>
							</a>
							<a class="ghost-button" href="/models">
								<span class="material-symbols-outlined">travel_explore</span>
								<span>Browse Models</span>
							</a>
						</div>
						<div class="hero-note">
							<span class="material-symbols-outlined">verified</span>
							<span>No paid plans. No card required. Community fair-use access.</span>
						</div>
					</div>

					<div class="hero-console" aria-label="FreeTheAi API example">
						<div class="console-glow"></div>
						<div class="code-card hero-code-card">
							<div class="card-head">
								<div class="dot-row"><span></span><span></span><span></span></div>
								<div class="card-label">OpenAI-compatible request</div>
							</div>
							<pre><code>{requestSnippet}</code></pre>
						</div>
						<div class="console-chip chip-a">
							<span class="material-symbols-outlined">stream</span>
							Streaming
						</div>
						<div class="console-chip chip-b">
							<span class="material-symbols-outlined">build</span>
							Tool calls
						</div>
						<div class="console-chip chip-c">
							<span class="material-symbols-outlined">imagesmode</span>
							Media
						</div>
					</div>
				</section>

				<section class="proof-grid" aria-label="FreeTheAi usage proof">
					{proofStats.map((stat) => (
						<article class="proof-card">
							<strong>{stat.value}</strong>
							<span>{stat.label}</span>
							<p>{stat.copy}</p>
						</article>
					))}
				</section>

				<section class="section split-section" id="quickstart">
					<div class="section-head sticky-copy">
						<div class="eyebrow">QUICKSTART</div>
						<h2>One Discord command, then normal SDK code.</h2>
						<p>
							The fastest path is not a dashboard. Join the server, run <code>/signup</code>,
							put the key in your environment, and point your OpenAI-compatible client at the API.
						</p>
						<a class="inline-link" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
							<span class="material-symbols-outlined">open_in_new</span>
							<span>Open the Discord signup flow</span>
						</a>
					</div>
					<div class="steps-grid vertical-steps">
						{quickSteps.map((step, index) => (
							<article class="step-card">
								<div class="step-index">0{index + 1}</div>
								<span class="material-symbols-outlined">{step.icon}</span>
								<h3>{step.title}</h3>
								<p>{step.copy}</p>
							</article>
						))}
					</div>
				</section>

				<section class="section" id="capabilities">
					<div class="section-head">
						<div class="eyebrow">API SURFACE</div>
						<h2>Enough routes to build real products, not just demos.</h2>
						<p>
							The gateway keeps the developer experience familiar while exposing multiple workloads behind
							one key. Model discovery belongs on the dedicated models page.
						</p>
					</div>
					<div class="capability-grid">
						{capabilities.map((item) => (
							<article class="capability-card">
								<div class="capability-icon">
									<span class="material-symbols-outlined">{item.icon}</span>
								</div>
								<h3>{item.title}</h3>
								<p>{item.copy}</p>
								<code>{item.route}</code>
							</article>
						))}
					</div>
				</section>

				<section class="section code-section" id="usage">
					<div class="section-head">
						<div class="eyebrow">COPY, PASTE, SHIP</div>
						<h2>Use the clients and agent frameworks you already have.</h2>
						<p>
							Start with chat completions for most apps. If a framework expects a messages route,
							use <code>/v1/messages</code> with the same bearer key.
						</p>
					</div>
					<div class="usage-grid">
						<div class="panel code-panel">
							<div class="panel-kicker">JavaScript SDK</div>
							<h3>OpenAI-compatible client</h3>
							<pre><code>{sdkSnippet}</code></pre>
						</div>
						<div class="panel code-panel">
							<div class="panel-kicker">Messages route</div>
							<h3>Anthropic-style request shape</h3>
							<pre><code>{messagesSnippet}</code></pre>
						</div>
					</div>
				</section>

				<section class="models-cta" id="models">
					<div>
						<div class="eyebrow">MODEL CATALOG</div>
						<h2>The full model list moved where it belongs.</h2>
						<p>
							The landing page should explain the product. The <a href="/models">models page</a>
							searches the live catalog, shows tiers, and lets builders find exact aliases without
							making the homepage feel like a data dump.
						</p>
					</div>
					<div class="model-orbit" aria-hidden="true">
						<div class="orbit-ring"></div>
						<div class="orbit-pill pill-one">chat</div>
						<div class="orbit-pill pill-two">tools</div>
						<div class="orbit-pill pill-three">media</div>
						<div class="orbit-pill pill-four">speech</div>
						<div class="orbit-center">/models</div>
					</div>
					<a class="primary-button" href="/models">
						<span class="material-symbols-outlined">search</span>
						<span>Search Live Models</span>
					</a>
				</section>

				<section class="section two-panel" id="free">
					<div class="panel free-panel">
						<div class="eyebrow">WHY FREE</div>
						<h2>We do not charge anything.</h2>
						<p>
							The point is access. FreeTheAi is community-run, with usage controls to keep the service
							usable for everyone instead of turning the homepage into a pricing table.
						</p>
						<ul class="privacy-list">
							{fairnessItems.map((item) => (
								<li>
									<span class="material-symbols-outlined">check_circle</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
					<div class="panel privacy-panel">
						<div class="eyebrow">PRIVACY POSTURE</div>
						<h2>Usage is measured. Prompt text is not stored.</h2>
						<div class="privacy-columns">
							<div>
								<h3>Tracked</h3>
								<ul class="privacy-list">
									<li><span class="material-symbols-outlined">check_circle</span>model id</li>
									<li><span class="material-symbols-outlined">check_circle</span>token counts</li>
									<li><span class="material-symbols-outlined">check_circle</span>status code</li>
									<li><span class="material-symbols-outlined">check_circle</span>timestamp</li>
								</ul>
							</div>
							<div>
								<h3>Not stored</h3>
								<ul class="privacy-list">
									<li><span class="material-symbols-outlined">block</span>prompt text</li>
									<li><span class="material-symbols-outlined">block</span>completion text</li>
									<li><span class="material-symbols-outlined">block</span>billing data</li>
									<li><span class="material-symbols-outlined">block</span>credit card data</li>
								</ul>
							</div>
						</div>
					</div>
				</section>

				<section class="cta-banner">
					<div>
						<div class="eyebrow">START NOW</div>
						<h2>Get a key, browse the catalog, and build.</h2>
						<p>
							Nearly 2,000 Discord members, 700+ registrations, and still no billing flow.
						</p>
					</div>
					<div class="cta-actions">
						<a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
							<span class="material-symbols-outlined">forum</span>
							<span>Join Discord</span>
						</a>
						<a class="ghost-button" href="/models">
							<span class="material-symbols-outlined">travel_explore</span>
							<span>Open Models</span>
						</a>
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
