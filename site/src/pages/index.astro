			'gpt-5.1',
			'gpt-5.2',
			'gpt-5.4-mini',
			'gpt-5.4',
			'claude-4-5-haiku',
			'claude-4-5-sonnet',
			'claude-4-6-sonnet',
			'gemini-2-5-flash',
			'gemini-3-flash',
			'gemini-3-1-pro',
		],
